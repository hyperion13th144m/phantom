                                {
                                    "tag": "text",
                                    "text": "１．特許法第２９条第２項 ",
                                    "isLastSentence": true
                                },
                                {
                                    "tag": "text",
                                    "text": "　審査官殿が拒絶理由のないとされた補正前の請求項２に限定したので、拒絶理由は解消したものと思料する。",
                                    "isLastSentence": true
                                },
                                {
                                    "tag": "text",
                                    "text": " ",
                                    "isLastSentence": true
                                },
                                {
                                    "tag": "text",
                                    "text": "３．結論",
                                    "isLastSentence": true
                                },
                                {
                                    "tag": "text",
                                    "text": "　以上説明したように、理由１に基づく拒絶理由は解消したものと思料する。",
                                    "isLastSentence": true
                                },
                                {
                                    "tag": "text",
                                    "text": "　よって、再度のご審査を賜り、本願発明が特許をするべきものであるとのご決定を下されることを希求する。",
                                    "isLastSentence": true
                                },
                                {
                                    "tag": "text",
                                    "text": " ",
                                    "isLastSentence": true
                                },
                                {
                                    "tag": "text",
                                    "text": " ",
                                    "isLastSentence": true
                                },
                                {
                                    "tag": "text",
                                    "text": "　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　　以　上",
                                    "isLastSentence": true
                                }
                            ]
                        }
                    ]
                },
                {
                    "tag": "jp:dtext",
                    "jpTag": "【その他】",
                    "text": "同日付で出願人名義変更届を提出致しました。",
