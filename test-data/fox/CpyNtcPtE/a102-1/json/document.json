                                                    "blocks": [
                                                        {
                                                            "tag": "text",
                                                            "text": "上記はファイルに記録されている事項と相違ないことを認証する。",
                                                            "isLastSentence": true
                                                        },
                                                        {
                                                            "tag": "text",
                                                            "text": "認証日　令和3年12月05日　経済産業事務官　審査官Ｆ",
