                                "blocks": [
                                  {
                                    "tag": "text",
                                    "text": "１．手続の経緯",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "　　出願　　　　　　　　　　　平成３０年０７月０８日",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "　　拒絶理由の通知（発送日）　令和　４年０６月０８日",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "　　意見書（提出日）　　　　　令和　４年０７月０８日",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "　　手続補正書（提出日）　　　令和　４年０７月０８日",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "　　拒絶査定（起案日）　　　　令和　４年０８月０８日",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "　　同　謄本送達（送達日）　　令和　４年０８月０８日",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "　　審判請求書（提出日）　　　令和　４年１１月０８日",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "　　手続補正書（提出日）　　　令和　４年１１月０８日",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": " ",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "２．拒絶査定の理由の要点",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "　拒絶査定は、拒絶をすべきものあり、要点は次の通りです。",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": " ",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "３．本願発明が特許されるべき理由",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "（１）本願発明の説明",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "（２）本願発明と引用文献との対比",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "４．むすび",
                                    "isLastSentence": true
                                  },
                                  {
                                    "tag": "text",
                                    "text": "　以上に述べたように、本願発明は引用文献１に記載された発明から当業者が容易に発明をすることができたものではありません。よって、原査定を取り消す、本願発明は特許すべきものとする、との審決を下さるようお願い致します。",
                                    "isLastSentence": true
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    ]
