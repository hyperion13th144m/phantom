{
    // IntelliSense を使用して利用可能な属性を学べます。
    // 既存の属性の説明をホバーして表示します。
    // 詳細情報は次を確認してください: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "single",
            "type": "debugpy",
            "request": "launch",
            "program": "src/mona/main.py",
            "console": "integratedTerminal",
            "args": "-m 1 -l info reference/src_dir reference/A163 A163"
        },
        {
            "name": "multi",
            "type": "debugpy",
            "request": "launch",
            "program": "src/mona/main.py",
            "console": "integratedTerminal",
            //"args": "-m 1 -l debug /src_dir/ /data_dir A163"
            "args": "-o -m 4 -l debug /src_dir/ /data_dir {A101,A102,A1131,A1191,A1192,A130,A1523,A163,A1631,A1632,A1634,A153,A159,A1781,A1871,A1872,A2242623}",
            //"args": "-o -m 1 -l debug /src_dir/ /data_dir A130"
            "env": {
                "OMP_THREAD_LIMIT": "1"
            }
        },
        {
            "name": "xslt",
            "type": "debugpy",
            "request": "launch",
            "program": "scripts/translate_xml.py",
            "console": "integratedTerminal",
            "args": [
                "${input:src_xml}",
                "${input:src_xsl}",
                "${input:out_name}"
            ]
        }
    ],
    "inputs": [
        {
            "id": "src_xml",
            "type": "promptString",
            "description": "input xml"
        },
        {
            "id": "src_xsl",
            "type": "promptString",
            "description": "src xsl",
            "default": "src/mona/stylesheets/2.0/application-body.xsl"
        },
        {
            "id": "out_name",
            "type": "pickString",
            "description": "output json",
            "default": "reference/0xsl-out/output.json",
            "options": [
                "reference/0xsl-out/output.json"
            ]
        }
    ]
}