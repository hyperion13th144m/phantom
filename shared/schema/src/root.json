{
    "$schema": "http://json-schema.org/draft/2020-12/schema",
    "title": "PatentDocument",
    "type": "object",
    "properties": {
        "docId": {
            "type": "string"
        },
        "schemaVer": {
            "type": "string"
        },
        "law": {
            "type": "string",
            "enum": [
                "patent",
                "utilityModel"
            ]
        },
        "documentName": {
            "type": "string"
        },
        "documentCode": {
            "type": "string"
        },
        "fileReferenceId": {
            "type": "string"
        },
        "registrationNumber": {
            "type": "string"
        },
        "applicationNumber": {
            "type": "string"
        },
        "internationalApplicationNumber": {
            "type": "string"
        },
        "appealReferenceNumber": {
            "type": "string"
        },
        "receiptNumber": {
            "type": "string"
        },
        "submissionDate": {
            "type": "string"
        },
        "submissionTime": {
            "type": "string"
        },
        "dispatchDate": {
            "type": "string"
        },
        "dispatchTime": {
            "type": "string"
        },
        "images": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "number": {
                        "type": "string"
                    },
                    "filename": {
                        "type": "string"
                    },
                    "kind": {
                        "type": "string"
                    },
                    "sizeTag": {
                        "type": "string"
                    },
                    "width": {
                        "type": "number"
                    },
                    "height": {
                        "type": "number"
                    },
                    "representative": {
                        "type": "boolean"
                    },
                    "description": {
                        "type": "string"
                    }
                },
                "required": [
                    "number",
                    "filename",
                    "kind",
                    "sizeTag",
                    "width",
                    "height",
                    "representative"
                ]
            }
        },
        "sources": {
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "filename": {
                        "type": "string"
                    },
                    "sha256": {
                        "type": "string"
                    },
                    "byte_size": {
                        "type": "number"
                    },
                    "task": {
                        "type": "string"
                    },
                    "kind": {
                        "type": "string"
                    },
                    "extension": {
                        "type": "string"
                    }
                },
                "required": [
                    "filename",
                    "sha256",
                    "byte_size",
                    "task",
                    "kind",
                    "extension"
                ]
            }
        },
        "fields": {
            "$ref": "#/$defs/fields"
        },
        "ocrText": {
            "type": "string"
        },
        "blocks": {
            "type": "array",
            "items": {
                "anyOf": [
                    {
                        "$ref": "#/$defs/pat-app-doc"
                    },
                    {
                        "$ref": "#/$defs/description"
                    },
                    {
                        "$ref": "#/$defs/claims"
                    },
                    {
                        "$ref": "#/$defs/abstract"
                    },
                    {
                        "$ref": "#/$defs/drawings"
                    },
                    {
                        "$ref": "#/$defs/pat-rspn"
                    },
                    {
                        "$ref": "#/$defs/pat-etc"
                    },
                    {
                        "$ref": "#/$defs/pat-amnd"
                    },
                    {
                        "$ref": "#/$defs/foreign-document"
                    },
                    {
                        "$ref": "#/$defs/notice-pat-exam"
                    },
                    {
                        "$ref": "#/$defs/notice-pat-exam-rn"
                    }
                ]
            }
        }
    },
    "required": [
        "docId",
        "sources",
        "schemaVer",
        "law",
        "documentName",
        "documentCode",
        "images",
        "fields",
        "ocrText",
        "blocks"
    ]
}