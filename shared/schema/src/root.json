        "documentName": {
            "type": "string"
        },
        "documentCode": {
            "type": "string"
        },
        "fileReferenceId": {
            "type": "string"
        },
        "registrationNumber": {
            "type": "string"
        },
        "applicationNumber": {
            "type": "string"
        },
        "internationalApplicationNumber": {
            "type": "string"
        },
        "appealReferenceNumber": {
            "type": "string"
        },
        "receiptNumber": {
            "type": "string"
        },
        "submissionDate": {
            "type": "string"
        },
        "submissionTime": {
            "type": "string"
        },
        "dispatchDate": {
            "type": "string"
        },
        "dispatchTime": {
            "type": "string"
        },
        "images": {
            "$ref": "./images.json"
        },
        "sources": {
            "$ref": "./sources.json"
        },
        "fields": {
            "$ref": "./fields.json"
        },
        "ocrText": {
            "type": "string"
        },
        "blocks": {
            "type": "array",
            "items": {
                "anyOf": [
                    {
                        "$ref": "#/$defs/pat-app-doc"
                    },
                    {
