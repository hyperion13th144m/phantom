---
import "../styles/global.css";
const title = Astro.props.title || "Document";
---

<html lang="ja">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
    </head>
    <body>
        <slot />
    </body>
</html>

<style>
    body {
        max-width: 40em;
        word-break: break-all;
    }
    :global(.application-item .jpTag) {
        @apply min-w-[12em];
    }
</style>
