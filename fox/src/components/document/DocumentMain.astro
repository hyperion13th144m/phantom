---
import BibBlock from "~/components/block-renderer/common/BibliographicBlock.astro";
import NoticeBibBlock from "~/components/block-renderer/common/NoticeBibliographicBlock.astro";
import Abstract from "~/components/block-renderer/pat-app-doc/Abstract.astro";
import Claims from "~/components/block-renderer/pat-app-doc/Claims.astro";
import Description from "~/components/block-renderer/pat-app-doc/Description.astro";
import Drawings from "~/components/block-renderer/pat-app-doc/Drawings.astro";
import ForeignDocument from "~/components/block-renderer/pat-app-doc/ForeignDocument.astro";
import BibliographicData from "~/components/document/BibliographicData.astro";
import Card from "~/components/ui/Card.astro";
import ImageCarousel from "~/components/ui/ImageCarousel.astro";
import KeywordHighlighter from "~/components/ui/KeywordHighlighter.astro";
import type { IPDocument } from "~/interfaces/document";
import { documentTypeGuards as g } from "~/interfaces/document-block";

const { ipDocument } = Astro.props as {
    ipDocument: IPDocument;
};
const lawPrefix = ipDocument.law === "patent" ? "特許" : "実用新案登録";
const images = ipDocument.images
    .filter((img) => img.kind.includes("figure"))
    .filter((img) => img.sizeTag === "middle")
    .sort((a, b) => a.number.localeCompare(b.number));
const thumbnails = ipDocument.images
    .filter((img) => img.kind.includes("figure"))
    .filter((img) => img.sizeTag === "thumbnail")
    .sort((a, b) => a.number.localeCompare(b.number));

const hasCarouselImages =
    images.length > 0 &&
    thumbnails.length > 0 &&
    images.length === thumbnails.length;

// 各セクションのブロックを抽出
const patAppDoc = ipDocument.textBlocksRoot
    .filter((block) => g.isPatAppDoc(block))
    .at(0);
const description = ipDocument.textBlocksRoot
    .filter((block) => g.isDescription(block))
    .at(0);
const claims = ipDocument.textBlocksRoot
    .filter((block) => g.isClaims(block))
    .at(0);
const abstract = ipDocument.textBlocksRoot
    .filter((block) => g.isAbstract(block))
    .at(0);
const drawings = ipDocument.textBlocksRoot
    .filter((block) => g.isDrawings(block))
    .at(0);

// 外国語書面出願
const foreignDescription = ipDocument.textBlocksRoot
    .filter((block) => g.isForeignDescription(block))
    .at(0);
const foreignClaims = ipDocument.textBlocksRoot
    .filter((block) => g.isForeignClaims(block))
    .at(0);
const foreignAbstract = ipDocument.textBlocksRoot
    .filter((block) => g.isForeignAbstract(block))
    .at(0);
const foreignDrawings = ipDocument.textBlocksRoot
    .filter((block) => g.isForeignDrawings(block))
    .at(0);

// 意見書のブロックを抽出
const patResponse = ipDocument.textBlocksRoot
    .filter((block) => g.isPatResponse(block))
    .at(0);

// 補正書のブロックを抽出
const patAmnd = ipDocument.textBlocksRoot
    .filter((block) => g.isPatAmnd(block))
    .at(0);

// 上申書のブロックを抽出
const patEtc = ipDocument.textBlocksRoot
    .filter((block) => g.isPatEtc(block))
    .at(0);

// 拒絶理由通知書等のブロックを抽出
const ntcPatExam = ipDocument.textBlocksRoot
    .filter((block) => g.isNoticePatExam(block) || g.isNoticePatExamRn(block))
    .at(0);
---

<BibliographicData ipDocument={ipDocument} />
<KeywordHighlighter urlParamKey="q">
    <div class={`grid gap-4 ${hasCarouselImages ? " lg:grid-cols-2" : ""}`}>
        <div data-search-root class="">
            {
                patAppDoc && (
                    <Card title={ipDocument.documentName}>
                        {patAppDoc.blocks.map((block) => (
                            <BibBlock block={block} />
                        ))}
                    </Card>
                )
            }
            {
                description && (
                    <Card title="明細書">
                        <Description description={description} />
                    </Card>
                )
            }
            {
                claims && (
                    <Card title={lawPrefix + "請求の範囲"}>
                        <Claims claims={claims} />
                    </Card>
                )
            }
            {
                abstract && (
                    <Card title="要約書">
                        <Abstract abstract={abstract} />
                    </Card>
                )
            }
            {
                drawings && (
                    <Card title="図面">
                        <Drawings drawings={drawings} />
                    </Card>
                )
            }
            {
                foreignDescription && (
                    <Card title="外国語明細書">
                        <ForeignDocument
                            block={foreignDescription}
                            sizeTag="large"
                        />
                    </Card>
                )
            }
            {
                foreignClaims && (
                    <Card title={"外国語" + lawPrefix + "請求の範囲"}>
                        <ForeignDocument
                            block={foreignClaims}
                            sizeTag="large"
                        />
                    </Card>
                )
            }
            {
                foreignAbstract && (
                    <Card title="外国語要約書">
                        <ForeignDocument
                            block={foreignAbstract}
                            sizeTag="large"
                        />
                    </Card>
                )
            }
            {
                foreignDrawings && (
                    <Card title="外国語図面">
                        <ForeignDocument
                            block={foreignDrawings}
                            sizeTag="large"
                        />
                    </Card>
                )
            }
            {
                patResponse && (
                    <Card title={ipDocument.documentName}>
                        {patResponse.blocks.map((block) => (
                            <BibBlock block={block} />
                        ))}
                    </Card>
                )
            }
            {
                patAmnd && (
                    <Card title={ipDocument.documentName}>
                        {patAmnd.blocks.map((block) => (
                            <BibBlock block={block} />
                        ))}
                    </Card>
                )
            }
            {
                patEtc && (
                    <Card title={ipDocument.documentName}>
                        {patEtc.blocks.map((block) => (
                            <BibBlock block={block} />
                        ))}
                    </Card>
                )
            }
            {
                ntcPatExam && (
                    <Card title={ipDocument.documentName}>
                        {ntcPatExam.blocks.map((block) => (
                            <NoticeBibBlock block={block} />
                        ))}
                    </Card>
                )
            }
        </div>
        {
            hasCarouselImages && (
                <div class="hidden lg:block">
                    <div class="sticky top-32 bg-white">
                        <Card title="図面一覧">
                            <ImageCarousel
                                docId={ipDocument.docId}
                                images={images}
                                thumbnails={thumbnails}
                                heightClass="h-[640px]"
                                thumbHeight={128}
                            />
                        </Card>
                    </div>
                </div>
            )
        }
    </div>
</KeywordHighlighter>
