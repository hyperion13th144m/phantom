---
import BibBlock from "~/components/block-renderer/common/BibliographicBlock.astro";
import NoticeBibBlock from "~/components/block-renderer/common/NoticeBibliographicBlock.astro";
import Abstract from "~/components/block-renderer/pat-app-doc/Abstract.astro";
import Claims from "~/components/block-renderer/pat-app-doc/Claims.astro";
import Description from "~/components/block-renderer/pat-app-doc/Description.astro";
import Drawings from "~/components/block-renderer/pat-app-doc/Drawings.astro";
import ForeignDocument from "~/components/block-renderer/pat-app-doc/ForeignDocument.astro";
import type { IPDocument } from "~/interfaces/document";
import { documentTypeGuards as g } from "~/interfaces/document-block";

const { ipDocument } = Astro.props as {
    ipDocument: IPDocument;
};

// 各セクションのブロックを抽出
const patAppDoc = ipDocument.textBlocksRoot
    .filter((block) => g.isPatAppDoc(block))
    .at(0);
const description = ipDocument.textBlocksRoot
    .filter((block) => g.isDescription(block))
    .at(0);
const claims = ipDocument.textBlocksRoot
    .filter((block) => g.isClaims(block))
    .at(0);
const abstract = ipDocument.textBlocksRoot
    .filter((block) => g.isAbstract(block))
    .at(0);
const drawings = ipDocument.textBlocksRoot
    .filter((block) => g.isDrawings(block))
    .at(0);

// 外国語書面出願
const foreignDescription = ipDocument.textBlocksRoot
    .filter((block) => g.isForeignDescription(block))
    .at(0);
const foreignClaims = ipDocument.textBlocksRoot
    .filter((block) => g.isForeignClaims(block))
    .at(0);
const foreignAbstract = ipDocument.textBlocksRoot
    .filter((block) => g.isForeignAbstract(block))
    .at(0);
const foreignDrawings = ipDocument.textBlocksRoot
    .filter((block) => g.isForeignDrawings(block))
    .at(0);

// 意見書のブロックを抽出
const patResponse = ipDocument.textBlocksRoot
    .filter((block) => g.isPatResponse(block))
    .at(0);

// 補正書のブロックを抽出
const patAmnd = ipDocument.textBlocksRoot
    .filter((block) => g.isPatAmnd(block))
    .at(0);

// 上申書のブロックを抽出
const patEtc = ipDocument.textBlocksRoot
    .filter((block) => g.isPatEtc(block))
    .at(0);

// 拒絶理由通知書等のブロックを抽出
const ntcPatExam = ipDocument.textBlocksRoot
    .filter((block) => g.isNoticePatExam(block) || g.isNoticePatExamRn(block))
    .at(0);
---

{patAppDoc && patAppDoc.blocks.map((block) => <BibBlock block={block} />)}

{description && <Description description={description} />}
{claims && <Claims claims={claims} />}
{abstract && <Abstract abstract={abstract} />}
{drawings && <Drawings drawings={drawings} />}
{
    foreignDescription && (
        <ForeignDocument block={foreignDescription} sizeTag="large" />
    )
}
{foreignClaims && <ForeignDocument block={foreignClaims} sizeTag="large" />}
{foreignAbstract && <ForeignDocument block={foreignAbstract} />}
{foreignDrawings && <ForeignDocument block={foreignDrawings} sizeTag="large" />}
{patResponse && patResponse.blocks.map((block) => <BibBlock block={block} />)}
{patAmnd && patAmnd.blocks.map((block) => <BibBlock block={block} />)}
{patEtc && patEtc.blocks.map((block) => <BibBlock block={block} />)}
{
    ntcPatExam &&
        ntcPatExam.blocks.map((block) => <NoticeBibBlock block={block} />)
}
