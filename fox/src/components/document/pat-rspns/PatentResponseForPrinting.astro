---
import BlockRenderer from "~/components/document/pat-app-doc/ApplicationFormBlockRenderer.astro";
import type { IPDocument } from "~/interfaces/document";
import { commonTypeGuards } from "~/interfaces/text-blocks-root";

const { ipDocument } = Astro.props as {
    ipDocument: IPDocument;
};

const title = ipDocument.documentName;

// 各セクションのブロックを抽出
const patResponse = ipDocument.textBlocksRoot
    .filter((block) => commonTypeGuards.isPatResponse(block))
    .at(0);
---

{
    patResponse &&
        patResponse.blocks.map((block) => <BlockRenderer block={block} />)
}
