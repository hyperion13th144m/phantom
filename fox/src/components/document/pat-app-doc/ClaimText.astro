---
import Inline from "~/components/document/common/Inline.astro";
import type { ClaimTextBlock } from "~/interfaces/claims";
import { concatBlocks } from "~/lib/blocks";

const { claimText } = Astro.props as {
    claimText: ClaimTextBlock;
};
---

<div class="claimText">
    {
        concatBlocks(claimText.blocks).map((group) => (
            <div>
                {group.map((g) => (
                    <Inline block={g} />
                ))}
            </div>
        ))
    }
</div>
