---
import type { ClaimBlock } from "~/interfaces/claims";
import ClaimText from "./ClaimText.astro";

const { claim } = Astro.props as {
    claim: ClaimBlock;
};
---

<div class="claim">
    <div class="jpTag">{claim.jpTag}</div>
    {claim.blocks.map((block) => <ClaimText claimText={block} />)}
</div>
