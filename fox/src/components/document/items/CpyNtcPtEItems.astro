---
import {
    type DispatchControlArticleItems,
    type NtcPtETerminalItemsTypeB,
} from "~/interfaces/generated/cpy-ntc-pt-e";
import {
    isCertificationColumnArticle,
    isCertificationColumnGroup,
    isDecisionOfRegistrationA01,
    isDecisionOfRejectionA02,
    isDispatchControlArticle,
    isExaminerNotificationA30,
    isImageContainer,
    isInlineText,
    isInquiryArticle,
    isNoticeOthers,
    isNoticePatExam,
    isNtcPtEContainerItemsTypeA,
    isNtcPtEContainerItemsTypeB,
    isNtcPtETerminalItemsTypeA,
    isNtcPtETerminalItemsTypeB,
    isParagraph,
} from "~/interfaces/generated/cpy-ntc-pt-e.guard";
import { concatBlocks } from "~/lib/concat-blocks";

const { block } = Astro.props as {
    block: any;
};
const imageInfo = isImageContainer(block)
    ? {
          url: typeof block.url === "string" ? block.url : block.file,
          width: typeof block.width === "number" ? block.width : undefined,
          height: typeof block.height === "number" ? block.height : undefined,
          alt: typeof block.alt === "string" ? block.alt : "",
      }
    : null;

/* isNtcPtETerminalItemsTypeB に含まれる要素のうち
   レンダリング内容を変えたい場合、変えたい要素を
   判定するガードを作成する. isDefaultNtcPtETerminalItemsTypeB から
   変えたい要素を除外する */
const isDocumentName = (block: unknown): block is NtcPtETerminalItemsTypeB =>
    isNtcPtETerminalItemsTypeB(block) && block.tag === "jp:document-name";
const isDefaultNtcPtETerminalItemsTypeB = (
    block: unknown,
): block is NtcPtETerminalItemsTypeB => {
    if (isNtcPtETerminalItemsTypeB(block) && block.tag === "jp:document-name") {
        return false;
    } else if (isNtcPtETerminalItemsTypeB(block)) {
        return true;
    } else {
        return false;
    }
};
---

{
    (isNoticePatExam(block) ||
        isDecisionOfRejectionA02(block) ||
        isDecisionOfRegistrationA01(block) ||
        isNtcPtEContainerItemsTypeA(block) ||
        isCertificationColumnArticle(block) ||
        isCertificationColumnGroup(block) ||
        isExaminerNotificationA30(block) ||
        isInquiryArticle(block) ||
        isNoticeOthers(block)) &&
        block.blocks &&
        block.blocks.map((block) => <Astro.self block={block} />)
}

{
    isDispatchControlArticle(block) && (
        <>
            {block.blocks.map((b: DispatchControlArticleItems) => (
                <div class="flex gap-2 text-xs">
                    <div class="min-w-[5em]">{b.jpTag}</div>
                    <div>{b.text}</div>
                </div>
            ))}
            <hr />
        </>
    )
}

{
    isNtcPtEContainerItemsTypeB(block) && (
        <>
            <div class="flex">
                <div
                    class={`jpTag indentLevel-${block.indentLevel} ${block.tag}`}
                    style="min-width: 11em;"
                >
                    {block.jpTag}
                </div>
            </div>
            {block.blocks && block.blocks.map((b) => <Astro.self block={b} />)}
        </>
    )
}

{
    isDocumentName(block) && (
        <div class="flex justify-center mt-2 text-2xl">
            <div class="min-w-[5em]">{block.convertedText ?? block.text}</div>
        </div>
    )
}

{
    (isDefaultNtcPtETerminalItemsTypeB(block) ||
        isNtcPtETerminalItemsTypeA(block)) && (
        <div class="flex gap-2">
            <div
                class={`indentLevel-${block.indentLevel}`}
                style="min-width: 12em;"
            >
                {block.jpTag}
            </div>
            <div class="text">{block.convertedText ?? block.text}</div>
        </div>
    )
}
{
    isParagraph(block) && (
        <>
            <div class={`indent-level-${block.indentLevel}`}>{block.jpTag}</div>
            {concatBlocks(block.blocks, (b) => b.isLastSentence === true).map(
                (group) => (
                    <div>
                        {group.map((b) => (
                            <Astro.self block={b} />
                        ))}
                    </div>
                ),
            )}
        </>
    )
}
{isInlineText(block) && block.tag === "text" && <span>{block.text}</span>}
{isInlineText(block) && block.tag === "sup" && <sup>{block.text}</sup>}
{isInlineText(block) && block.tag === "sub" && <sub>{block.text}</sub>}
{isInlineText(block) && block.tag === "underline" && <u>{block.text}</u>}
{
    isImageContainer(block) && imageInfo && (
        <div class="image-container">
            <div class={`indent-level-${block.indentLevel}`}>{block.jpTag}</div>
            <img
                src={imageInfo.url}
                alt={block.alt}
                width={imageInfo.width}
                height={imageInfo.height}
                style="max-width: 100%; height: auto;"
            />
        </div>
    )
}
