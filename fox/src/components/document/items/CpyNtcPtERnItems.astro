---
import { getImageUrl } from "~/constants";
import {
    type DispatchControlArticleItems,
    type NtcPtERnTerminalItemsTypeB,
} from "~/interfaces/generated/cpy-ntc-pt-e-rn";
import {
    isCertificationColumnArticle,
    isCertificationColumnGroup,
    isDecisionOfRegistrationA01Rn,
    isDecisionOfRejectionA02Rn,
    isDispatchControlArticle,
    isExaminerNotificationA30Rn,
    isImageContainer,
    isInlineText,
    isInquiryArticle,
    isNoticeOthersRn,
    isNoticePatExamRn,
    isNtcPtERnContainerItemsTypeA,
    isNtcPtERnContainerItemsTypeB,
    isNtcPtERnTerminalItemsTypeA,
    isNtcPtERnTerminalItemsTypeB,
    isParagraph,
} from "~/interfaces/generated/cpy-ntc-pt-e-rn.guard";
import { concatBlocks } from "~/lib/concat-blocks";

const { block } = Astro.props as {
    block: any;
};
const { docId } = Astro.params as { docId: string };
const imageInfo = isImageContainer(block)
    ? await getImageUrl(docId, block.file, "large")
    : null;

/* isNtcPtETerminalItemsTypeB に含まれる要素のうち
   レンダリング内容を変えたい場合、変えたい要素を
   判定するガードを作成する. isDefaultNtcPtETerminalItemsTypeB から
   変えたい要素を除外する */
const isDocumentName = (block: unknown): block is NtcPtERnTerminalItemsTypeB =>
    isNtcPtERnTerminalItemsTypeB(block) && block.tag === "jp:document-name";
const isDefaultNtcPtERnTerminalItemsTypeB = (
    block: unknown,
): block is NtcPtERnTerminalItemsTypeB => {
    if (
        isNtcPtERnTerminalItemsTypeB(block) &&
        block.tag === "jp:document-name"
    ) {
        return false;
    } else if (isNtcPtERnTerminalItemsTypeB(block)) {
        return true;
    } else {
        return false;
    }
};
---

{
    (isNoticePatExamRn(block) ||
        isDecisionOfRejectionA02Rn(block) ||
        isDecisionOfRegistrationA01Rn(block) ||
        isNtcPtERnContainerItemsTypeA(block) ||
        isCertificationColumnArticle(block) ||
        isCertificationColumnGroup(block) ||
        isExaminerNotificationA30Rn(block) ||
        isInquiryArticle(block) ||
        isNoticeOthersRn(block)) &&
        block.blocks &&
        block.blocks.map((block) => <Astro.self block={block} />)
}

{
    isDispatchControlArticle(block) && (
        <>
            {block.blocks.map((b: DispatchControlArticleItems) => (
                <div class="flex gap-2 text-xs">
                    <div class="min-w-[5em]">{b.jpTag}</div>
                    <div>{b.text}</div>
                </div>
            ))}
            <hr />
        </>
    )
}

{
    isNtcPtERnContainerItemsTypeB(block) && (
        <>
            <div class="flex">
                <div
                    class={`jpTag indentLevel-${block.indentLevel} ${block.tag}`}
                    style="min-width: 11em;"
                >
                    {block.jpTag}
                </div>
            </div>
            {block.blocks && block.blocks.map((b) => <Astro.self block={b} />)}
        </>
    )
}

{
    isDocumentName(block) && (
        <div class="flex justify-center mt-2 text-2xl">
            <div class="min-w-[5em]">{block.convertedText ?? block.text}</div>
        </div>
    )
}

{
    (isDefaultNtcPtERnTerminalItemsTypeB(block) ||
        isNtcPtERnTerminalItemsTypeA(block)) && (
        <div class="flex gap-2">
            <div
                class={`indentLevel-${block.indentLevel}`}
                style="min-width: 12em;"
            >
                {block.jpTag}
            </div>
            <div class="text">{block.convertedText ?? block.text}</div>
        </div>
    )
}
{
    isParagraph(block) && (
        <>
            <div class={`indent-level-${block.indentLevel}`}>{block.jpTag}</div>
            {concatBlocks(block.blocks, (b) => b.isLastSentence === true).map(
                (group) => (
                    <div>
                        {group.map((b) => (
                            <Astro.self block={b} />
                        ))}
                    </div>
                ),
            )}
        </>
    )
}
{isInlineText(block) && block.tag === "text" && <span>{block.text}</span>}
{isInlineText(block) && block.tag === "sup" && <sup>{block.text}</sup>}
{isInlineText(block) && block.tag === "sub" && <sub>{block.text}</sub>}
{isInlineText(block) && block.tag === "underline" && <u>{block.text}</u>}
{
    isImageContainer(block) && imageInfo && (
        <div class="image-container">
            <div class={`indent-level-${block.indentLevel}`}>{block.jpTag}</div>
            <img
                src={imageInfo.url}
                alt={block.alt}
                width={imageInfo.width}
                height={imageInfo.height}
                style="max-width: 100%; height: auto;"
            />
        </div>
    )
}
