---
// ApplicationBody の文書の表示用/印刷用レイアウトを定義、
// 子要素は items/ApplicationBodyItems.astro で定義する。
import Card from "~/components/ui/Card.astro";
import type { ApplicationBody } from "~/interfaces/generated/application-body";
import {
    isAbstract,
    isClaims,
    isDescription,
    isDrawings,
} from "~/interfaces/generated/application-body.guard";
import ApplicationBodyItems from "./items/ApplicationBodyItems.astro";
const { document, forPrinting = false } = Astro.props as {
    document: ApplicationBody;
    forPrinting: boolean;
};
const displayOrder = [isAbstract, isClaims, isDescription, isDrawings];
const printingOrder = [isDescription, isClaims, isAbstract, isDrawings];
const order = forPrinting ? printingOrder : displayOrder;
const sortedDocs = order
    .map((guard) => document.blocks.find((b) => guard(b)))
    .filter((b): b is NonNullable<typeof b> => b !== undefined);
---

{
    forPrinting === false &&
        sortedDocs.map((block) => (
            <Card title={block.text}>
                <div>
                    {block.jpTag}
                    {block.text}
                </div>
                {block.blocks.map((b) => (
                    <ApplicationBodyItems block={b} />
                ))}
            </Card>
        ))
}

{
    forPrinting === true &&
        sortedDocs.map((block) => (
            <div class={block.tag}>
                <div>
                    {block.jpTag}
                    {block.text}
                </div>
                {block.blocks.map((b) => (
                    <ApplicationBodyItems block={b} />
                ))}
            </div>
        ))
}

<!-- for printing -->
<style>
    .claims {
        break-before: page;
    }
    .description {
        break-before: page;
    }
    .abstract {
        break-before: page;
    }
    .drawings {
        break-before: page;
    }
</style>
