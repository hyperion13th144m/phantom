---
import Card from "~/components/ui/Card.astro";
import ImageCarousel from "~/components/ui/ImageCarousel.astro";
import type { IPDocument } from "~/interfaces/document";
import { checker } from "~/interfaces/text-blocks-root";
import Abstract from "./Abstract.astro";
import ApplicationForm from "./ApplicationForm.astro";
import BibliographicData from "./BibliographicData.astro";
import Claims from "./Claims.astro";
import Description from "./Description.astro";
import Drawings from "./Drawings.astro";
import ForeignLanguageDocumentBlock from "./ForeignLanguageDocument.astro";

const { ipDocument } = Astro.props as {
    ipDocument: IPDocument;
};
const lawPrefix = ipDocument.law === "patent" ? "特許" : "実用新案登録";
const images = ipDocument.images
    .filter((img) => img.kind.includes("figure"))
    .filter((img) => img.sizeTag === "middle")
    .sort((a, b) => a.number.localeCompare(b.number));
const thumbnails = ipDocument.images
    .filter((img) => img.kind.includes("figure"))
    .filter((img) => img.sizeTag === "thumbnail")
    .sort((a, b) => a.number.localeCompare(b.number));

const hasCarouselImages =
    images.length > 0 &&
    thumbnails.length > 0 &&
    images.length === thumbnails.length;

// 各セクションのブロックを抽出
const applicationForm = ipDocument.textBlocksRoot
    .filter((block) => checker.isApplicationForm(block))
    .at(0);
const description = ipDocument.textBlocksRoot
    .filter((block) => checker.isDescription(block))
    .at(0);
const claims = ipDocument.textBlocksRoot
    .filter((block) => checker.isClaims(block))
    .at(0);
const abstract = ipDocument.textBlocksRoot
    .filter((block) => checker.isAbstract(block))
    .at(0);
const drawings = ipDocument.textBlocksRoot
    .filter((block) => checker.isDrawings(block))
    .at(0);

// 外国語書面出願
const foreignDescription = ipDocument.textBlocksRoot
    .filter((block) => checker.isForeignDescription(block))
    .at(0);
const foreignClaims = ipDocument.textBlocksRoot
    .filter((block) => checker.isForeignClaims(block))
    .at(0);
const foreignAbstract = ipDocument.textBlocksRoot
    .filter((block) => checker.isForeignAbstract(block))
    .at(0);
const foreignDrawings = ipDocument.textBlocksRoot
    .filter((block) => checker.isForeignDrawings(block))
    .at(0);
---

<BibliographicData ipDocument={ipDocument} />
<div class={`grid gap-4 ${hasCarouselImages ? " lg:grid-cols-2" : ""}`}>
    <div class="">
        <main id="doc-content">
            {
                applicationForm && (
                    <Card title={`${lawPrefix}願`}>
                        <ApplicationForm applicationForm={applicationForm} />
                    </Card>
                )
            }
            {
                description && (
                    <Card title="明細書">
                        <Description description={description} />
                    </Card>
                )
            }
            {
                claims && (
                    <Card title={lawPrefix + "請求の範囲"}>
                        <Claims claims={claims} />
                    </Card>
                )
            }
            {
                abstract && (
                    <Card title="要約書">
                        <Abstract {...abstract} />
                    </Card>
                )
            }
            {
                drawings && (
                    <Card title="図面">
                        <Drawings drawings={drawings} />
                    </Card>
                )
            }
            {
                foreignDescription && (
                    <Card title="外国語明細書">
                        <ForeignLanguageDocumentBlock
                            block={foreignDescription}
                            sizeTag="large"
                        />
                    </Card>
                )
            }
            {
                foreignClaims && (
                    <Card title={"外国語" + lawPrefix + "請求の範囲"}>
                        <ForeignLanguageDocumentBlock
                            block={foreignClaims}
                            sizeTag="large"
                        />
                    </Card>
                )
            }
            {
                foreignAbstract && (
                    <Card title="外国語要約書">
                        <ForeignLanguageDocumentBlock
                            block={foreignAbstract}
                            sizeTag="large"
                        />
                    </Card>
                )
            }
            {
                foreignDrawings && (
                    <Card title="外国語図面">
                        <ForeignLanguageDocumentBlock
                            block={foreignDrawings}
                            sizeTag="large"
                        />
                    </Card>
                )
            }
        </main>
    </div>
    {
        hasCarouselImages && (
            <div class="hidden lg:block">
                <div class="sticky top-32 bg-white">
                    <Card title="図面一覧">
                        <ImageCarousel
                            images={images}
                            thumbnails={thumbnails}
                            heightClass="h-[640px]"
                            thumbHeight={128}
                        />
                    </Card>
                </div>
            </div>
        )
    }
</div>
