---
import Print from "~/components/icons/Print.astro";
import type { IPDocument } from "~/interfaces/document";
import Minus from "~/components/icons/Minus.astro";
import Plus from "~/components/icons/Plus.astro";
import BreadCrumbs from "~/components/ui/BreadCrumbs.astro";
export interface Props {
    ipDocument: IPDocument;
}

const { ipDocument } = Astro.props;
---

<nav class="header-nav">
    <!-- 1段目 PC/smartphone 双方で表示される -->
    <div class="flex items-center justify-between gap-2">
        <BreadCrumbs
            crumbs={[
                { title: "HOME", href: "/" },
                { title: "出願書類", href: "/docs" },
                {
                    title: "出願番号の一覧",
                    href: "/docs/applicationNumbers",
                },
                {
                    title: ipDocument.applicationNumber.toString(),
                    href: `/docs/applicationNumbers/${ipDocument.applicationNumber.slug}`,
                },
                {
                    title: ipDocument.documentName,
                    href: Astro.url.pathname,
                },
            ]}
        />
        <!-- ハンバーガー：スマホだけ表示 -->
        <button
            type="button"
            class="md:hidden inline-flex items-center justify-center rounded-md border bg-white px-3 py-2 shadow-sm"
            aria-label="メニューを開く"
            aria-controls="mobileNavPanel"
            aria-expanded="false"
            data-nav-toggle
        >
            <!-- アイコンは何でもOK（lucide の Menu でも、文字でも） -->
            <span class="text-xl leading-none">☰</span>
        </button>
    </div>

    <!-- 2段目 PCで表示, スマホではドロワー -->
    <div class="hidden md:block mt-3">
        <div class="flex items-center justify-between">
            <div class="flex gap-4">
                <div class="bg-orange-200 rounded-md shadow-md px-2">
                    <!-- 出願番号 -->
                    <a
                        href={`/docs/applicationNumbers/${ipDocument.applicationNumber.slug}`}
                        class="hover:text-blue-600"
                    >
                        {ipDocument.applicationNumber.toString()}
                    </a>
                </div>
                <div class="bg-violet-200 rounded-md shadow-md px-2">
                    <!-- 整理番号 -->
                    <a
                        href={`/docs/fileReferenceId/${ipDocument.fileReferenceId}`}
                        class="hover:text-blue-600"
                    >
                        {ipDocument.fileReferenceId}
                    </a>
                </div>
                <div class="flex gap-2">
                    <!-- 発明者 -->
                    {
                        ipDocument.inventors.length > 0 &&
                            ipDocument.inventors.map((inv) => (
                                <div class="bg-cyan-100 rounded-md shadow-md px-2">
                                    <a
                                        href={`/docs/inventors/${encodeURIComponent(inv)}`}
                                        class="hover:text-blue-600"
                                    >
                                        {inv}
                                    </a>
                                </div>
                            ))
                    }
                </div>
                <div class="flex gap-2">
                    <!-- 出願人 -->
                    {
                        ipDocument.applicants.length > 0 &&
                            ipDocument.applicants.map((app) => (
                                <div class="bg-green-100 rounded-md shadow-md px-2">
                                    <a
                                        href={`/docs/applicants/${encodeURIComponent(app)}`}
                                        class="hover:text-blue-600"
                                    >
                                        {app}
                                    </a>
                                </div>
                            ))
                    }
                </div>
            </div>
            <div class="flex justify-end gap-4">
                <div
                    id="keyword-nav"
                    data-keyword-nav
                    class="flex items-center gap-2 px-2 py-1"
                >
                    <span class="status" data-status></span>
                </div>
                <div class="flex items-center content-center" data-nav-search>
                    <div class="flex pt-1 nav-search gap-1">
                        <input
                            type="search"
                            id="nav-search-input"
                            placeholder="キーワード追加"
                            aria-label="検索キーワード"
                            class="border rounded-md w-40 bg-white"
                            data-nav-search-input
                        />
                        <button
                            type="button"
                            id="nav-search-add-button"
                            class="cursor-pointer"
                            data-nav-search-add-button
                        >
                            <div class="pt-1">
                                <Plus size="2em" />
                            </div>
                        </button>
                        <button
                            type="button"
                            id="nav-search-remove-button"
                            class="cursor-pointer"
                            data-nav-search-remove-button
                        >
                            <div class="pt-1">
                                <Minus size="2em" />
                            </div>
                        </button>
                        <div
                            id="nav-suggest-popover"
                            role="listbox"
                            aria-label="キーワード候補"
                            hidden
                            style="
                          position:absolute; top:100%; right:0;
                          border:1px solid #ccc; background:#fff;
                          min-width:14rem; box-shadow:0 6px 20px rgba(0,0,0,.12);
                          padding:.25rem; border-radius:.5rem;
                          z-index:1000;
                        "
                            data-nav-suggest-popover
                        >
                        </div>
                        <a
                            href={Astro.url.pathname + "/print"}
                            target="_blank"
                            rel="noopener noreferrer"
                        >
                            <Print size="3em" />
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- スマホ用 オーバーレイ＋パネル（ドロワー） -->
    <div class="md:hidden">
        <!-- 背景オーバーレイ -->
        <div
            class="fixed inset-0 bg-black/40 hidden"
            data-nav-overlay
            aria-hidden="true"
        >
        </div>

        <!-- パネル本体 -->
        <div
            id="mobileNavPanel"
            class="fixed top-0 right-0 h-dvh w-[min(92vw,420px)] bg-gray-100 shadow-2xl p-4 hidden overflow-y-auto"
            role="dialog"
            aria-modal="true"
            aria-label="ナビゲーション"
            data-nav-panel
        >
            <div class="flex items-center justify-between">
                <div class="font-semibold">メニュー</div>
                <button
                    type="button"
                    class="rounded-md border bg-white px-3 py-2 shadow-sm"
                    aria-label="メニューを閉じる"
                    data-nav-close
                >
                    ✕
                </button>
            </div>

            <hr class="my-3 border-gray-300" />

            <!-- ここにもナビ中身を置く（PC用と同じ構造） -->
            <div class="space-y-4">
                <div class="flex flex-wrap gap-2">
                    <div class="bg-orange-200 rounded-md shadow-md px-2">
                        <!-- 出願番号 -->
                        <a
                            href={`/docs/applicationNumbers/${ipDocument.applicationNumber.slug}`}
                            class="hover:text-blue-600"
                        >
                            {ipDocument.applicationNumber.toString()}
                        </a>
                    </div>
                    <div class="bg-violet-200 rounded-md shadow-md px-2">
                        <!-- 整理番号 -->
                        <a
                            href={`/docs/fileReferenceId/${ipDocument.fileReferenceId}`}
                            class="hover:text-blue-600"
                        >
                            {ipDocument.fileReferenceId}
                        </a>
                    </div>
                    {
                        ipDocument.inventors.length > 0 &&
                            ipDocument.inventors.map((inv) => (
                                <div class="bg-cyan-100 rounded-md shadow-md px-2">
                                    <a
                                        href={`/docs/inventors/${encodeURIComponent(inv)}`}
                                        class="hover:text-blue-600"
                                    >
                                        {inv}
                                    </a>
                                </div>
                            ))
                    }

                    {
                        ipDocument.applicants.length > 0 &&
                            ipDocument.applicants.map((app) => (
                                <div class="bg-green-100 rounded-md shadow-md px-2">
                                    <a
                                        href={`/docs/applicants/${encodeURIComponent(app)}`}
                                        class="hover:text-blue-600"
                                    >
                                        {app}
                                    </a>
                                </div>
                            ))
                    }
                </div>

                <div class="flex items-center justify-between gap-3">
                    <div
                        id="keyword-nav-mobile"
                        data-keyword-nav
                        class="flex items-center gap-2 px-2 py-1"
                    >
                        <span class="status" data-status></span>
                    </div>

                    <a
                        href={Astro.url.pathname + "/print"}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="shrink-0"
                    >
                        <Print size="3em" />
                    </a>
                </div>

                <div data-nav-search>
                    <div class="nav-search flex items-center gap-2 relative">
                        <input
                            type="search"
                            id="nav-search-input-mobile"
                            placeholder="キーワード追加"
                            aria-label="検索キーワード"
                            class="border rounded-md w-full bg-white"
                            data-nav-search-input
                        />
                        <button
                            type="button"
                            id="nav-search-add-button-mobile"
                            class="cursor-pointer shrink-0"
                            data-nav-search-add-button
                        >
                            <Plus size="2em" />
                        </button>
                        <button
                            type="button"
                            id="nav-search-remove-button-mobile"
                            class="cursor-pointer shrink-0"
                            data-nav-search-remove-button
                        >
                            <Minus size="2em" />
                        </button>

                        <div
                            id="nav-suggest-popover-mobile"
                            role="listbox"
                            aria-label="キーワード候補"
                            hidden
                            data-nav-suggest-popover
                            style="position:absolute; top:100%; right:0; border:1px solid #ccc; background:#fff; min-width:14rem; box-shadow:0 6px 20px rgba(0,0,0,.12); padding:.25rem; border-radius:.5rem; z-index:1000;"
                        >
                        </div>

                        <!-- モバイルでは、キーワードを表示するだけ。タップしてもジャンプしない -->
                    </div>
                    <div class="flex gap-2" id="display-keywords-for-mobile">
                    </div>
                </div>
            </div>
        </div>
    </div>
</nav>
<script>
    (() => {
        function removeKeyword(keyord: string) {
            // 既存のキーワードから削除対象をフィルタ
            const keywords = Array.from(getCurrentKeywords()).filter(
                (kw) => kw !== keyord,
            );

            const url = new URL(window.location.href);
            url.searchParams.set("q", Array.from(keywords).join(","));

            // ページ遷移
            window.location.href = url.toString();
        }

        function initNavSearch(root: Element) {
            const input = root.querySelector(
                "[data-nav-search-input]",
            ) as HTMLInputElement;
            const addBtn = root.querySelector(
                "[data-nav-search-add-button]",
            ) as HTMLButtonElement;
            const removeBtn = root.querySelector(
                "[data-nav-search-remove-button]",
            ) as HTMLButtonElement;
            const popover = root.querySelector(
                "[data-nav-suggest-popover]",
            ) as HTMLDivElement;

            if (!input || !addBtn || !removeBtn || !popover) return;

            function closePopover() {
                popover.hidden = true;
                removeBtn.setAttribute("aria-expanded", "false");
            }

            function openPopover() {
                // 中身を作る（都度生成でOK）
                popover.innerHTML = "";
                const keywords = getCurrentKeywords();
                keywords.forEach((kw) => {
                    const btn = document.createElement("button");
                    btn.type = "button";
                    btn.role = "option";
                    btn.textContent = kw;
                    btn.style.cssText = `
        display:block; width:100%; text-align:left;
        padding:.45rem .55rem; border:0; background:transparent;
        border-radius:.35rem; cursor:pointer;
      `;
                    btn.addEventListener(
                        "mouseenter",
                        () => (btn.style.background = "#f3f3f3"),
                    );
                    btn.addEventListener(
                        "mouseleave",
                        () => (btn.style.background = "transparent"),
                    );

                    // 「候補を選んだら q をURLから削除」＝検索解除
                    btn.addEventListener("click", () => {
                        closePopover();
                        removeKeyword(kw);
                    });

                    popover.appendChild(btn);
                });

                popover.hidden = false;
                removeBtn.setAttribute("aria-expanded", "true");
            }

            function addKeywords() {
                if (!input) return;
                const inputKeywords = input.value
                    .split(/,|\s+/)
                    .map((s) => s.trim())
                    .filter((s) => s);
                if (!inputKeywords.length) return;

                const url = new URL(window.location.href);

                // 既存のキーワードを取得
                const keywords = getCurrentKeywords();

                // 新しいキーワードを追加
                inputKeywords.forEach((kw) => {
                    if (kw) keywords.add(kw);
                });

                input.value = "";

                // クエリパラメータを更新
                url.searchParams.set("q", Array.from(keywords).join(","));

                // ページ遷移
                window.location.href = url.toString();
            }

            // 外側クリックで閉じる
            document.addEventListener("click", (e) => {
                const within =
                    popover.contains(e.target as Node) ||
                    removeBtn.contains(e.target as Node);
                if (!within) closePopover();
            });

            // Escで閉じる
            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape") closePopover();
            });

            addBtn.addEventListener("click", addKeywords);

            // Enterキー対応
            input.addEventListener("keydown", (e) => {
                if (e.key === "Enter") {
                    e.preventDefault();
                    addKeywords();
                }
            });

            removeBtn.addEventListener("click", () => {
                const keywords = getCurrentKeywords();
                if (keywords.size === 0) return; // キーワードがなければ何もしない
                if (popover.hidden) openPopover();
                else closePopover();
            });
        }

        document.querySelectorAll("[data-nav-search]").forEach((root) => {
            initNavSearch(root);
        });
    })();

    function getCurrentKeywords(): Set<string> {
        const url = new URL(window.location.href);
        const keywords = new Set<string>();
        const currentKeywords = url.searchParams.get("q");
        if (currentKeywords) {
            currentKeywords
                .split(",")
                .map((s) => s.trim())
                .forEach((kw) => {
                    if (kw) keywords.add(kw);
                });
        }
        return keywords;
    }

    window.onload = () => {
        // モバイル用キーワード表示を更新
        const element = document.getElementById("display-keywords-for-mobile");
        if (element) {
            element.innerHTML = "";
            const keywords = getCurrentKeywords();
            keywords.forEach((kw) => {
                const div = document.createElement("div");
                div.textContent = kw;
                element.appendChild(div);
            });
        }
    };
</script>

<!-- トグル用JS（ページ内で完結） -->
<script is:inline>
    (() => {
        const toggleBtn = document.querySelector("[data-nav-toggle]");
        const panel = document.querySelector("[data-nav-panel]");
        const overlay = document.querySelector("[data-nav-overlay]");
        const closeBtn = document.querySelector("[data-nav-close]");

        if (!toggleBtn || !panel || !overlay) return;

        const open = () => {
            panel.classList.remove("hidden");
            overlay.classList.remove("hidden");
            toggleBtn.setAttribute("aria-expanded", "true");
            document.documentElement.style.overflow = "hidden";
        };

        const close = () => {
            panel.classList.add("hidden");
            overlay.classList.add("hidden");
            toggleBtn.setAttribute("aria-expanded", "false");
            document.documentElement.style.overflow = "";
        };

        toggleBtn.addEventListener("click", open);
        overlay.addEventListener("click", close);
        closeBtn?.addEventListener("click", close);

        // ESCで閉じる
        window.addEventListener("keydown", (e) => {
            if (e.key === "Escape" && !panel.classList.contains("hidden"))
                close();
        });

        // 画面がmd以上になったら強制的に閉じる（表示崩れ防止）
        const mq = window.matchMedia("(min-width: 768px)");
        mq.addEventListener?.("change", (e) => {
            if (e.matches) close();
        });
    })();
</script>
