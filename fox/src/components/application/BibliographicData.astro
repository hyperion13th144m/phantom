---
import Print from "~/components/icons/Print.astro";
import type { IBibliographicData } from "~/interfaces/bibliographic-data";
import { formatApplicationNumber } from "~/lib/bib-utils";
import Minus from "../icons/Minus.astro";
import Plus from "../icons/Plus.astro";
export interface Props {
    bibData: IBibliographicData;
}

const { bibData } = Astro.props;

const appNumber = formatApplicationNumber(
    bibData.law,
    bibData.applicationNumber,
);
---

<nav class="sticky top-0 mb-4 bg-gray-100 z-10 p-4 rounded-md shadow-md">
    <div class="flex items-center justify-between">
        <div class="flex gap-4">
            <div class="bg-gray-300 rounded-md shadow-md px-2">
                <a
                    href={`/docs/applicationNumbers/${bibData.law}-${bibData.applicationNumber}`}
                    class="hover:text-blue-600"
                >
                    {appNumber}
                </a>
            </div>
            <div class="flex gap-2">
                {
                    bibData.inventors.length > 0 &&
                        bibData.inventors.map((inv) => (
                            <div class="bg-cyan-100 rounded-md shadow-md px-2">
                                <a
                                    href={`/docs/inventors/${encodeURIComponent(inv)}`}
                                    class="hover:text-blue-600"
                                >
                                    {inv}
                                </a>
                            </div>
                        ))
                }
            </div>
            <div class="flex gap-2">
                {
                    bibData.applicants.length > 0 &&
                        bibData.applicants.map((app) => (
                            <div class="bg-green-100 rounded-md shadow-md px-2">
                                <a
                                    href={`/docs/applicants/${encodeURIComponent(app)}`}
                                    class="hover:text-blue-600"
                                >
                                    {app}
                                </a>
                            </div>
                        ))
                }
            </div>
        </div>
        <div class="flex justify-end gap-4">
            <div
                id="keyword-nav"
                data-keyword-nav
                class="flex items-center gap-2 px-2 py-1"
            >
                <span class="status" data-status></span>
            </div>
            <div class="flex items-center content-center">
                <div class="flex pt-1 nav-search gap-1">
                    <input
                        type="search"
                        id="nav-search-input"
                        placeholder="キーワード追加"
                        aria-label="検索キーワード"
                        class="border rounded-md w-40 bg-white"
                    />
                    <button
                        type="button"
                        id="nav-search-add-button"
                        class="cursor-pointer"
                    >
                        <div class="pt-1">
                            <Plus size="2em" />
                        </div>
                    </button>
                    <button
                        type="button"
                        id="nav-search-remove-button"
                        class="cursor-pointer"
                    >
                        <div class="pt-1">
                            <Minus size="2em" />
                        </div>
                    </button>
                    <div
                        id="nav-suggest-popover"
                        role="listbox"
                        aria-label="キーワード候補"
                        hidden
                        style="
                          position:absolute; top:100%; right:0;
                          border:1px solid #ccc; background:#fff;
                          min-width:14rem; box-shadow:0 6px 20px rgba(0,0,0,.12);
                          padding:.25rem; border-radius:.5rem;
                          z-index:1000;
                        "
                    >
                    </div>
                    <a
                        href={Astro.url + "/print"}
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <Print size="3em" />
                    </a>
                </div>
            </div>
        </div>
    </div>

    <script>
        const input = document.getElementById(
            "nav-search-input",
        ) as HTMLInputElement;
        const button = document.getElementById(
            "nav-search-add-button",
        ) as HTMLButtonElement;
        const suggestBtn = document.getElementById(
            "nav-search-remove-button",
        ) as HTMLButtonElement;
        const popover = document.getElementById(
            "nav-suggest-popover",
        ) as HTMLDivElement;

        function getCurrentKeywords(): Set<string> {
            const url = new URL(window.location.href);
            const keywords = new Set<string>();
            const currentKeywords = url.searchParams.get("q");
            if (currentKeywords) {
                currentKeywords
                    .split(",")
                    .map((s) => s.trim())
                    .forEach((kw) => {
                        if (kw) keywords.add(kw);
                    });
            }
            return keywords;
        }

        function addKeywords() {
            if (!input) return;
            const inputKeywords = input.value
                .split(/,|\s+/)
                .map((s) => s.trim())
                .filter((s) => s);
            if (!inputKeywords.length) return;

            const url = new URL(window.location.href);

            // 既存のキーワードを取得
            const keywords = getCurrentKeywords();

            // 新しいキーワードを追加
            inputKeywords.forEach((kw) => {
                if (kw) keywords.add(kw);
            });

            input.value = "";

            // クエリパラメータを更新
            url.searchParams.set("q", Array.from(keywords).join(","));

            // ページ遷移
            window.location.href = url.toString();
        }

        function removeKeyword(keyord: string) {
            // 既存のキーワードから削除対象をフィルタ
            const keywords = Array.from(getCurrentKeywords()).filter(
                (kw) => kw !== keyord,
            );

            const url = new URL(window.location.href);
            url.searchParams.set("q", Array.from(keywords).join(","));

            // ページ遷移
            window.location.href = url.toString();
        }

        function closePopover() {
            popover.hidden = true;
            suggestBtn.setAttribute("aria-expanded", "false");
        }

        function openPopover() {
            // 中身を作る（都度生成でOK）
            popover.innerHTML = "";
            const keywords = getCurrentKeywords();
            keywords.forEach((kw) => {
                const btn = document.createElement("button");
                btn.type = "button";
                btn.role = "option";
                btn.textContent = kw;
                btn.style.cssText = `
        display:block; width:100%; text-align:left;
        padding:.45rem .55rem; border:0; background:transparent;
        border-radius:.35rem; cursor:pointer;
      `;
                btn.addEventListener(
                    "mouseenter",
                    () => (btn.style.background = "#f3f3f3"),
                );
                btn.addEventListener(
                    "mouseleave",
                    () => (btn.style.background = "transparent"),
                );

                // 「候補を選んだら q をURLから削除」＝検索解除
                btn.addEventListener("click", () => {
                    closePopover();
                    removeKeyword(kw);
                });

                popover.appendChild(btn);
            });

            popover.hidden = false;
            suggestBtn.setAttribute("aria-expanded", "true");
        }

        button.addEventListener("click", addKeywords);
        suggestBtn.addEventListener("click", () => {
            const keywords = getCurrentKeywords();
            if (keywords.size === 0) return; // キーワードがなければ何もしない
            if (popover.hidden) openPopover();
            else closePopover();
        });

        // Enterキー対応
        input.addEventListener("keydown", (e) => {
            if (e.key === "Enter") {
                e.preventDefault();
                addKeywords();
            }
        });

        // 外側クリックで閉じる
        document.addEventListener("click", (e) => {
            const within =
                popover.contains(e.target as Node) ||
                suggestBtn.contains(e.target as Node);
            if (!within) closePopover();
        });

        // Escで閉じる
        document.addEventListener("keydown", (e) => {
            if (e.key === "Escape") closePopover();
        });
    </script>
</nav>
