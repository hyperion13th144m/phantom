---
// 特許出願書類の明細書を表示するためのコンポーネント
import { type Block, checker } from "~/interfaces/text-blocks-root";
import Paragraph from "./Paragraph.astro";

const { block } = Astro.props as {
    block: Block;
};
---

{
    // 発明の名称
    checker.isInventionTitle(block) && (
        <div class={block.tag} style="display: flex;">
            <div class={`jpTag indentLevel-${block.indentLevel}`}>
                {block.jpTag}
            </div>
            <div class="text">{block.text}</div>
        </div>
    )
}

{
    // 技術分野、背景技術、先行技術文献、特許文献,非特許文献，発明の概要,発明の開示
    // 発明が解決しようとする課題, 課題を解決する手段, 発明の効果
    // 図面の簡単な説明, 発明を実施するための形態, 実施例
    // 産業上の利用可能性, 配列表, 符号の説明, 受託番号
    (checker.isTechnicalField(block) ||
        checker.isBackgroundArt(block) ||
        checker.isCitationList(block) ||
        checker.isPatentLiterature(block) ||
        checker.isNonPatentLiterature(block) ||
        checker.isSummaryOfInvention(block) ||
        checker.isDisclosure(block) ||
        checker.isTechProblem(block) ||
        checker.isTechSolution(block) ||
        checker.isAdvantageousEffects(block) ||
        checker.isDescriptionOfDrawings(block) ||
        checker.isDescriptionOfEmbodiments(block) ||
        checker.isBestMode(block) ||
        checker.isEmbodimentExample(block) ||
        checker.isModeForInvention(block) ||
        checker.isIndustrialApplicability(block) ||
        checker.isSequenceListText(block) ||
        checker.isReferenceSignsList(block) ||
        checker.isReferenceToDepositedBiologicalMaterial(block)) && (
        <div class={block.tag}>
            <div class={`jpTag indentLevel-${block.indentLevel}`}>
                {block.jpTag}
            </div>
            {block.blocks.map((b) => (
                <Astro.self block={b} />
            ))}
        </div>
    )
}

{
    // 段落
    checker.isParagraph(block) && <Paragraph block={block} />
}

<style>
    .figref {
        @apply flex;
    }
</style>
