---
// 特許出願書類の図面を表示するためのコンポーネント

import type { DrawingsBlock } from "~/interfaces/text-blocks-root";
import Figure from "./Figure.astro";

interface Props {
    sizeTag?: "thumbnail" | "middle" | "large";
    drawings: DrawingsBlock;
}
const { drawings, sizeTag = "middle" } = Astro.props as Props;
---

<div class="drawings">
    <div class="jpTag">{drawings.jpTag}</div>
    {
        drawings.blocks.map((figure) => (
            <Figure block={figure} sizeTag={sizeTag} />
        ))
    }
</div>

<style>
    .drawings {
        break-before: page;
    }

    .drawings :global(.figure:not(:last-child)) {
        break-after: page;
    }
</style>
