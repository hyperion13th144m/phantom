---
// 特許出願書類の図面を表示するためのコンポーネント

import type { DrawingsBlock } from "~/interfaces/application";
import Figure from "./Figure.astro";

interface Props {
    basePath: string;
    sizeTag?: "thumbnail" | "middle" | "large";
    drawings: DrawingsBlock;
}
const { basePath, drawings, sizeTag = "middle" } = Astro.props as Props;
---

<div class="drawings">
    <div class="jpTag">{drawings.jpTag}</div>
    {
        drawings.blocks.map((figure) => (
            <Figure basePath={basePath} block={figure} sizeTag={sizeTag} />
        ))
    }
</div>
