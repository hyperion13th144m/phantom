---
// 特許出願書類の特許請求の範囲を表示するためのコンポーネント

import type { ClaimsBlock } from "~/interfaces/text-blocks-root";
import Claim from "./Claim.astro";

const { claims } = Astro.props as {
    claims: ClaimsBlock;
};
---

<div class="claims">
    <div class="jpTag">{claims.jpTag}</div>
    {claims.blocks.map((claim) => <Claim claim={claim} />)}
</div>

<style>
    .claims {
        break-before: page;
    }
</style>
