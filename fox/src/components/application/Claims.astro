---
// 特許出願書類の特許請求の範囲を表示するためのコンポーネント

import type { ClaimsBlock } from "~/interfaces/application";
import Claim from "./Claim.astro";

const { claims, basePath } = Astro.props as {
    claims: ClaimsBlock;
    basePath: string;
};
---

<div class="claims">
    <div class="jpTag">{claims.jpTag}</div>
    {claims.blocks.map((claim) => <Claim claim={claim} basePath={basePath} />)}
</div>
