---
import BlockRenderer from "~/components/application/ApplicationFormBlockRenderer.astro";
import type { ApplicationFormBlock } from "~/interfaces/text-blocks-root";

const { applicationForm } = Astro.props as {
    applicationForm: ApplicationFormBlock;
};
---

<div class="applicationForm">
    {applicationForm.blocks.map((block) => <BlockRenderer block={block} />)}
</div>
