---
import type { ApplicationFormItemBlock } from "~/interfaces/text-blocks-root";
import { concatBlocks } from "~/lib/blocks";
import Inline from "./Inline.astro";

const { block } = Astro.props as {
    block: ApplicationFormItemBlock;
};

const isUndefinedBlock = (tag: string) => {
    const defined = ["jp:dispatch-control-article"];
    const flag = defined.includes(tag);
    return !flag;
};
---

{
    block.tag == "jp:dispatch-control-article" && (
        <>
            {block.blocks.map((b) => (
                <div class="flex gap-2 text-sm">
                    <div class="min-w-[5em]">{b.jpTag}</div>
                    <div>{b.text}</div>
                </div>
            ))}
            <hr />
        </>
    )
}

{
    block.tag == "jp:opinion-contents-article" && (
        <div>
            <div class={`jpTag indentLevel-${block.indentLevel}`}>
                {block.jpTag}
            </div>
            {concatBlocks(block.blocks).map((group) => (
                <div>
                    {group.map((b) => (
                        <Inline block={b} />
                    ))}
                </div>
            ))}
        </div>
    )
}

{
    /** jpTag ○, convertedText 〇
     */
    (block.tag == "jp:document-code" ||
        block.tag == "jp:doc-number" ||
        block.tag == "jp:account" ||
        block.tag == "jp:fee" ||
        block.tag == "jp:document-name" ||
        block.tag == "jp:application-reference" ||
        block.tag == "jp:special-mention-matter-article" ||
        block.tag == "jp:date") && (
        <div class="application-item" style="display: flex;">
            <span
                class={`jpTag indentLevel-${block.indentLevel}`}
                style="min-width: 11em;"
            >
                {block.jpTag}
            </span>
            <span class="convertedText">{block.convertedText}</span>
        </div>
    )
}

{
    /** jpTag ○, text 〇,  convertedText ×
     */
    (block.tag == "jp:addressed-to-person" ||
        block.tag == "jp:file-reference-id" ||
        block.tag == "jp:registered-number" ||
        block.tag == "jp:name" ||
        block.tag == "jp:dispatch-number" ||
        block.tag == "jp:ipc" ||
        block.tag == "jp:text" ||
        block.tag == "jp:general-power-of-attorney-id") && (
        <div class="application-item" style="display: flex;">
            <span
                class={`jpTag indentLevel-${block.indentLevel}`}
                style="min-width: 11em;"
            >
                {block.jpTag}
            </span>
            <span class="text">{block.text}</span>
        </div>
    )
}

{
    /** tag ○, jpTag ○, text ×, blocks ○ */
    (block.tag == "jp:indication-of-case-article" ||
        block.tag == "jp:applicant" ||
        block.tag == "jp:agent" ||
        block.tag == "jp:attorney" ||
        block.tag == "jp:inventor" ||
        block.tag == "jp:charge-article" ||
        block.tag == "jp:submission-object-list-article" ||
        block.tag == "jp:earlier-app" ||
        block.tag == "jp:parent-application-article") && (
        <>
            <div class="application-item" style="display: flex;">
                <span
                    class={`jpTag indentLevel-${block.indentLevel}`}
                    style="min-width: 11em;"
                >
                    {block.jpTag}
                </span>
            </div>
            {block?.blocks?.map((b) => (
                <Astro.self block={b} />
            ))}
        </>
    )
}

{
    /** tag ○, blocks ○ */
    (block.tag == "jp:applicants" ||
        block.tag == "jp:agents" ||
        block.tag == "jp:inventors" ||
        block.tag == "jp:attorney-change-article" ||
        block.tag == "jp:declaration-priority-ear-app") &&
        block.blocks?.map((childBlock) => <Astro.self block={childBlock} />)
}

{
    /** 未対応のブロックタグ */
    isUndefinedBlock(block.tag) && (
        <div>
            <h1>no renderer for this block</h1>
            <pre>{JSON.stringify(block, null, 2)}</pre>
        </div>
    )
}

<style>
    .application-item :global(.indentLevel-2) {
        text-indent: 2em;
    }
</style>
