---
// 特許出願書類の明細書を表示するためのコンポーネント

import type { DescriptionBlock } from "~/interfaces/application";
import BlockRenderer from "./BlockRenderer.astro";

const { basePath, description } = Astro.props as {
    basePath: string;
    description: DescriptionBlock;
};
---

<div class="description">
    <div class="jpTag">{description.jpTag}</div>
    {
        description.blocks.map((block) => (
            <BlockRenderer basePath={basePath} block={block} />
        ))
    }
</div>
