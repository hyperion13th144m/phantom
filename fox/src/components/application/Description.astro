---
// 特許出願書類の明細書を表示するためのコンポーネント

import type { DescriptionBlock } from "~/interfaces/text-blocks-root";
import BlockRenderer from "./BlockRenderer.astro";

const { description } = Astro.props as {
    description: DescriptionBlock;
};
---

<div class="description">
    <div class="jpTag">{description.jpTag}</div>
    {description.blocks.map((block) => <BlockRenderer block={block} />)}
</div>
