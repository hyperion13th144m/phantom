---
// 特許出願書類の図を表示するためのコンポーネント
import { getBaseUrl } from "~/constants";
import type { ImageContainerBlock } from "~/interfaces/document-block";
interface Props {
    sizeTag?: "thumbnail" | "middle" | "large";
    block: ImageContainerBlock;
}
const { block, sizeTag = "middle" } = Astro.props as Props;
const cls =
    block.tag === "figures"
        ? "figures"
        : block.tag === "tables"
          ? "tables"
          : block.tag === "equations"
            ? "equations"
            : block.tag === "chemical-formulas"
              ? "chemical-formulas"
              : "other-images";
const baseUrlPath = Astro.params.docId ? getBaseUrl(Astro.params.docId) : "";
---

<div class={cls}>
    <div class={`jpTag indentLevel-${block.indentLevel}`}>{block.jpTag}</div>
    {
        block.images
            .filter((image) => image.sizeTag === sizeTag)
            .map((image) => (
                <img
                    src={baseUrlPath + "/" + image.src}
                    alt={"alt" in block ? (block.alt ?? "") : ""}
                />
            ))
    }
</div>
