---
import BreadCrumbs from "~/components/ui/BreadCrumbs.astro";
import Layout from "~/layouts/Layout.astro";
import { formatApplicationNumber } from "~/lib/bib-utils";
import { getContentInfo, getDocIdPaths } from "~/lib/getDocPaths.js";

type ApplicantProps = {
    docId: string;
    applicationNumber: string;
    documentName: string;
    law: "patent" | "utilityModel";
    submissionDate: string;
};
export async function getStaticPaths() {
    const applicantProps: Record<string, ApplicantProps[]> = {};
    const docIdList = await getDocIdPaths();
    for (const p of docIdList) {
        const contentInfo = await getContentInfo(p.params.docId);
        contentInfo.bibData.applicants.forEach((applicant) => {
            if (!applicantProps[applicant]) {
                applicantProps[applicant] = [];
            }
            applicantProps[applicant].push({
                docId: p.params.docId,
                law: contentInfo.bibData.law,
                applicationNumber: contentInfo.bibData.applicationNumber,
                documentName: contentInfo.bibData.documentName,
                submissionDate: contentInfo.bibData.submissionDate,
            });
        });
    }
    docIdList.forEach(async ({ params }) => {});
    return Object.entries(applicantProps).map(([applicant, props]) => ({
        params: { applicant },
        props: { applicant, documents: props },
    }));
}

const { applicant } = Astro.params;
const { documents } = Astro.props;
const docs = documents.sort((a, b) =>
    a.submissionDate.localeCompare(b.submissionDate),
);
---

<Layout title={`出願人別文書一覧 | ${applicant}`}>
    <main>
        <nav class="header-nav">
            <BreadCrumbs
                crumbs={[
                    { title: "HOME", href: "/" },
                    { title: "出願書類", href: "/docs" },
                    { title: "出願人の一覧", href: "/docs/applicants" },
                    {
                        title: applicant,
                        href: `/docs/applicants/${applicant}`,
                    },
                ]}
            />
        </nav>

        <section>
            <ul class="list-disc list-inside">
                {
                    docs.map(
                        ({ docId, law, applicationNumber, documentName }) => (
                            <li>
                                <a
                                    href={`/docs/applicationNumbers/${law}-${applicationNumber}`}
                                    class="text-blue-600 hover:underline"
                                >
                                    {formatApplicationNumber(
                                        law,
                                        applicationNumber,
                                    )}
                                </a>
                            </li>
                        ),
                    )
                }
            </ul>
        </section>
    </main>
</Layout>
