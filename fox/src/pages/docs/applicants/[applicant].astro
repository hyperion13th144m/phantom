---
import BreadCrumbs from "~/components/ui/BreadCrumbs.astro";
import type { IPDocument } from "~/interfaces/document";
import Layout from "~/layouts/Layout.astro";
import { getDocIds } from "~/lib/getDocPaths";
import { getIPDocument } from "~/lib/getIPDocument";

export async function getStaticPaths() {
    const applicantProps: Record<string, IPDocument[]> = {};
    const docIdList = await getDocIds();
    for (const p of docIdList) {
        const ipDocument = await getIPDocument(p.params.docId);
        ipDocument.applicants.forEach((applicant) => {
            if (!applicantProps[applicant]) {
                applicantProps[applicant] = [];
            }
            applicantProps[applicant].push(ipDocument);
        });
    }
    return Object.entries(applicantProps).map(([applicant, ipDocuments]) => ({
        params: { applicant },
        props: { ipDocuments },
    }));
}

const { applicant } = Astro.params;
const { ipDocuments } = Astro.props;
const groupedDocs = Object.groupBy(
    ipDocuments,
    (doc) => doc.applicationNumber.yearPart ?? "出願年不明",
);
const indecies = Object.keys(groupedDocs).sort((a, b) => a.localeCompare(b));
---

<Layout title={`出願人別文書一覧 | ${applicant}`}>
    <main class="p-4">
        <BreadCrumbs
            crumbs={[
                { title: "HOME", href: "/" },
                { title: "出願書類", href: "/docs" },
                { title: "出願人の一覧", href: "/docs/applicants" },
                {
                    title: applicant,
                    href: `/docs/applicants/${applicant}`,
                },
            ]}
        />

        <section>
            <h1 class="text-2xl font-bold">{applicant}の出願一覧</h1>
            <span class="text-sm text-gray-600">
                総数: {ipDocuments.length} 件
            </span>
            {
                indecies.map((index) => (
                    <h2>{index}年</h2>
                    <ul class="pl-[2em] list-disc list-inside">
                        {groupedDocs[index]?.map((ipDocument) => (
                            <li>
                                <a
                                    href={`/docs/applicationNumbers/${ipDocument.applicationNumber.slug}`}
                                    class="text-blue-600 hover:underline"
                                >
                                    {ipDocument.applicationNumber.toString()}
                                    {ipDocument.fileReferenceId &&
                                        ` (${ipDocument.fileReferenceId})`}
                                </a>
                            </li>
                        ))}
                    </ul>
                ))
            }
        </section>
    </main>
</Layout>

