---
import BreadCrumbs from "~/components/ui/BreadCrumbs.astro";
import type { IPDocument } from "~/interfaces/document";
import Layout from "~/layouts/Layout.astro";
import { getDocIds } from "~/lib/getDocPaths";
import { getIPDocument } from "~/lib/getIPDocument";

export async function getStaticPaths() {
    const applicantProps: Record<string, IPDocument[]> = {};
    const docIdList = await getDocIds();
    for (const p of docIdList) {
        const ipDocument = await getIPDocument(p.params.docId);
        ipDocument.applicants.forEach((applicant) => {
            if (!applicantProps[applicant]) {
                applicantProps[applicant] = [];
            }
            applicantProps[applicant].push(ipDocument);
        });
    }
    return Object.entries(applicantProps).map(([applicant, ipDocuments]) => ({
        params: { applicant },
        props: { ipDocuments },
    }));
}

const { applicant } = Astro.params;
const { ipDocuments } = Astro.props;
const docs = ipDocuments.sort((a, b) =>
    a.submissionDate.date > b.submissionDate.date ? 1 : -1,
);
---

<Layout title={`出願人別文書一覧 | ${applicant}`}>
    <main>
        <nav class="header-nav">
            <BreadCrumbs
                crumbs={[
                    { title: "HOME", href: "/" },
                    { title: "出願書類", href: "/docs" },
                    { title: "出願人の一覧", href: "/docs/applicants" },
                    {
                        title: applicant,
                        href: `/docs/applicants/${applicant}`,
                    },
                ]}
            />
        </nav>

        <section>
            <ul class="list-disc list-inside">
                {
                    docs.map(({ applicationNumber, fileReferenceId }) => (
                        <li>
                            <a
                                href={`/docs/applicationNumbers/${applicationNumber.slug}`}
                                class="text-blue-600 hover:underline"
                            >
                                {`${applicationNumber.toString()} (${fileReferenceId})`}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </section>
    </main>
</Layout>
