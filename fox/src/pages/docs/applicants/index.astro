---
import sqlite from "better-sqlite3";
import BreadCrumbs from "~/components/ui/BreadCrumbs.astro";
import { INDEX_DB } from "~/constant";
import Layout from "~/layouts/Layout.astro";

export const prerender = true;
const db = new sqlite(INDEX_DB);
const rows = db
    .prepare(`SELECT DISTINCT slug, name FROM applicants ORDER BY name ASC`)
    .all() as Array<{
    slug: string;
    name: string;
}>;
db.close();
---

<Layout title="出願人の一覧">
    <main class="p-4">
        <BreadCrumbs
            crumbs={[
                { title: "HOME", href: "/" },
                { title: "出願人の一覧", href: "/docs/applicants" },
            ]}
        />

        <section>
            <h1 class="text-xl font-bold">出願人の一覧</h1>
            {
                rows.map((applicant) => (
                    <div class="mt-6">
                        <div class="pl-4 flex flex-col gap-2">
                            <a
                                href={`../docs/applicants/${applicant.slug}`}
                                class="text-blue-600 hover:underline"
                            >
                                {applicant.name}
                            </a>
                        </div>
                    </div>
                ))
            }
        </section>
    </main>
</Layout>
