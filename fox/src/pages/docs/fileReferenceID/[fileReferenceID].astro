---
import BreadCrumbs from "~/components/ui/BreadCrumbs.astro";
import Layout from "~/layouts/Layout.astro";
import { formatDateString } from "~/lib/bib-utils";
import { getDocIds, getDocument } from "~/lib/getDocPaths";

type ApplicationInfo = {
    law: "patent" | "utilityModel";
    applicationNumber: string;
    fileReferenceID: string;
    documents: DocumentInfo[];
};
type DocumentInfo = {
    docId: string;
    documentName: string;
    submissionDate: string;
};
export async function getStaticPaths() {
    const appInfoList: Record<string, ApplicationInfo> = {};
    const docIdList = await getDocIds();
    for (const p of docIdList) {
        const contentInfo = await getDocument(p.params.docId);
        const appNum = `${contentInfo.document.law}-${contentInfo.document.applicationNumber}`;
        const fileReferenceID = contentInfo.document.fileReferenceId;
        if (!appInfoList[fileReferenceID]) {
            appInfoList[fileReferenceID] = {
                law: contentInfo.document.law,
                applicationNumber: contentInfo.document.applicationNumber ?? "",
                fileReferenceID: contentInfo.document.fileReferenceId ?? "",
                documents: [],
            };
        }
        appInfoList[fileReferenceID].documents.push({
            docId: p.params.docId,
            documentName: contentInfo.document.documentName,
            submissionDate: contentInfo.document.submissionDate,
        });
    }
    return Object.entries(appInfoList).map(([fileReferenceID, props]) => ({
        params: { fileReferenceID },
        props: { appInfo: props },
    }));
}

const { fileReferenceID } = Astro.params;
const { appInfo } = Astro.props;
const docs = appInfo.documents.sort((a, b) =>
    a.submissionDate.localeCompare(b.submissionDate),
);
---

<Layout title={`整理番号別文書一覧 | ${fileReferenceID}`}>
    <main>
        <nav class="header-nav">
            <BreadCrumbs
                crumbs={[
                    { title: "HOME", href: "/" },
                    { title: "出願書類", href: "/docs" },
                    { title: "整理番号の一覧", href: "/docs/fileReferenceID" },
                    {
                        title: fileReferenceID,
                        href: `/docs/fileReferenceID/${fileReferenceID}`,
                    },
                ]}
            />
        </nav>

        <section>
            <ul class="list-disc list-inside">
                {
                    docs.map(({ docId, documentName, submissionDate }) => (
                        <li>
                            <span>{formatDateString(submissionDate)}</span>
                            <a
                                href={`/docs/${docId}`}
                                class="text-blue-600 hover:underline"
                            >
                                {documentName}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </section>
    </main>
</Layout>
