---
import BreadCrumbs from "~/components/ui/BreadCrumbs.astro";
import type { IPDocument } from "~/interfaces/document";
import Layout from "~/layouts/Layout.astro";
import { getDocIds } from "~/lib/getDocPaths";
import { getIPDocument } from "~/lib/getIPDocument";

export async function getStaticPaths() {
    const inventorProps: Record<string, IPDocument[]> = {};
    const docIdList = await getDocIds();
    for (const p of docIdList) {
        const ipDocument = await getIPDocument(p.params.docId);
        ipDocument.inventors.forEach((inventor) => {
            if (!inventorProps[inventor]) {
                inventorProps[inventor] = [];
            }
            inventorProps[inventor].push(ipDocument);
        });
    }
    return Object.entries(inventorProps).map(([inventor, ipDocuments]) => ({
        params: { inventor },
        props: { ipDocuments },
    }));
}

const { inventor } = Astro.params;
const { ipDocuments } = Astro.props;
const docs = ipDocuments.sort((a, b) =>
    a.submissionDate.date > b.submissionDate.date ? 1 : -1,
);
---

<Layout title={`発明者別文書一覧 | ${inventor}`}>
    <main>
        <BreadCrumbs
            crumbs={[
                { title: "HOME", href: "/" },
                { title: "出願書類", href: "/docs" },
                { title: "発明者の一覧", href: "/docs/inventors" },
                {
                    title: inventor,
                    href: `/docs/inventors/${inventor}`,
                },
            ]}
        />
        <section>
            <ul class="list-disc list-inside">
                {
                    docs.map(({ applicationNumber, fileReferenceId }) => (
                        <li>
                            <a
                                href={`/docs/applicationNumbers/${applicationNumber.slug}`}
                                class="text-blue-600 hover:underline"
                            >
                                {`${applicationNumber.toString()} (${fileReferenceId})`}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </section>
    </main>
</Layout>
