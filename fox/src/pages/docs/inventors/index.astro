---
import BreadCrumbs from "~/components/ui/BreadCrumbs.astro";
import Layout from "~/layouts/Layout.astro";
import { getDocIds } from "~/lib/getDocPaths";
import { getIPDocument } from "~/lib/getIPDocument";

const inventors = new Set<string>();
const docIdList = await getDocIds();
for (const p of docIdList) {
    const ipDocument = await getIPDocument(p.params.docId);
    ipDocument.inventors.forEach((inventor) => {
        inventors.add(inventor);
    });
}
const sortedInventors = Array.from(inventors).sort();
---

<Layout title="発明者の一覧">
    <main class="p-4">
        <BreadCrumbs
            crumbs={[
                { title: "HOME", href: "/" },
                { title: "出願書類", href: "/docs" },
                { title: "発明者の一覧", href: "/docs/inventors" },
            ]}
        />

        <section>
            <ul class="list-disc list-inside">
                {
                    sortedInventors.map((inventor) => (
                        <li>
                            <a
                                href={`/docs/inventors/${inventor}`}
                                class="text-blue-600 hover:underline"
                            >
                                {inventor}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </section>
    </main>
</Layout>
