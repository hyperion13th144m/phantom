---
import BreadCrumbs from "~/components/ui/BreadCrumbs.astro";
import type { IPDocument } from "~/interfaces/document";
import Layout from "~/layouts/Layout.astro";
import { getDocIds } from "~/lib/getDocPaths";
import { getIPDocument } from "~/lib/getIPDocument";

export async function getStaticPaths() {
    const refNumberProps: Record<string, IPDocument[]> = {};
    const docIdList = await getDocIds();
    for (const p of docIdList) {
        const ipDocument = await getIPDocument(p.params.docId);
        if (!refNumberProps[ipDocument.fileReferenceId]) {
            refNumberProps[ipDocument.fileReferenceId] = [];
        }
        refNumberProps[ipDocument.fileReferenceId].push(ipDocument);
    }
    return Object.entries(refNumberProps).map(
        ([fileReferenceId, ipDocuments]) => ({
            params: { fileReferenceId },
            props: { ipDocuments },
        }),
    );
}

const { fileReferenceId } = Astro.params;
const { ipDocuments } = Astro.props;
const docs = ipDocuments.sort((a, b) =>
    a.submissionDate.date > b.submissionDate.date ? 1 : -1,
);
---

<Layout title={`整理番号別文書一覧 | ${fileReferenceId}`}>
    <main>
        <nav class="header-nav">
            <BreadCrumbs
                crumbs={[
                    { title: "HOME", href: "/" },
                    { title: "出願書類", href: "/docs" },
                    { title: "整理番号の一覧", href: "/docs/fileReferenceId" },
                    {
                        title: fileReferenceId,
                        href: `/docs/fileReferenceId/${fileReferenceId}`,
                    },
                ]}
            />
        </nav>

        <section>
            <ul class="list-disc list-inside">
                {
                    docs.map(({ docId, documentName, submissionDate }) => (
                        <li>
                            <span>{submissionDate.toString()}</span>
                            <a
                                href={`/docs/${docId}`}
                                class="text-blue-600 hover:underline"
                            >
                                {documentName}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </section>
    </main>
</Layout>
