---
import BreadCrumbs from "~/components/ui/BreadCrumbs.astro";
import Layout from "~/layouts/Layout.astro";
import { formatApplicationNumber } from "~/lib/bib-utils";
import { getDocIds, getDocument } from "~/lib/getDocPaths.js";

const appNumbers: Record<
    string,
    { law: "patent" | "utilityModel"; number: string }
> = {};
const docIdList = await getDocIds();
for (const p of docIdList) {
    const contentInfo = await getDocument(p.params.docId);
    const key = `${contentInfo.document.law}-${contentInfo.document.applicationNumber}`;
    appNumbers[key] = {
        law: contentInfo.document.law,
        number: contentInfo.document.applicationNumber ?? "",
    };
}
const sortedAppNumbers = Object.values(appNumbers).sort((a, b) => {
    if (a.law !== b.law) {
        return a.law.localeCompare(b.law);
    } else {
        return a.number.localeCompare(b.number);
    }
});
---

<Layout title="出願番号の一覧">
    <main>
        <nav class="header-nav">
            <BreadCrumbs
                crumbs={[
                    { title: "HOME", href: "/" },
                    { title: "出願書類", href: "/docs" },
                    {
                        title: "出願番号の一覧",
                        href: "/docs/applicationNumbers",
                    },
                ]}
            />
        </nav>

        <section>
            <ul class="list-disc list-inside">
                {
                    sortedAppNumbers.map((appNumber) => (
                        <li>
                            <a
                                href={`/docs/applicationNumbers/${appNumber.law}-${appNumber.number}`}
                                class="text-blue-600 hover:underline"
                            >
                                {formatApplicationNumber(
                                    appNumber.law,
                                    appNumber.number,
                                )}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </section>
    </main>
</Layout>
