---
import BreadCrumbs from "~/components/ui/BreadCrumbs.astro";
import type { IPDocument } from "~/interfaces/document";
import Layout from "~/layouts/Layout.astro";
import type { ApplicationNumberIndexEntry } from "~/interfaces/index/application-number-index";
import _applicationNumberIndex from "../../../../public/content/_indexes/application-number-index.json";

const applicationNumberIndex: Record<
    string,
    ApplicationNumberIndexEntry
> = _applicationNumberIndex;

// 出願番号で2段階グループ化
// 1段階目=yearPart, 2段階目=applicationNumber.toString()
const groupedByYearAndAppNumber: Record<
    string,
    Record<string, IPDocument[]>
> = {};

const appNumbers = Object.keys(applicationNumberIndex).map((slug) => (
    {
        slug: slug,
        applicationNumberString:
            applicationNumberIndex[slug].applicationNumberString,
        yearPart: applicationNumberIndex[slug].yearPart,
        numOfDocs: applicationNumberIndex[slug].documents.length,
        fileReferenceId: applicationNumberIndex[slug].documents
            .map(doc => doc.fileReferenceId)
            .filter(ref => ref != null)
            .at(0) ?? "",
    }
));
const groupedAppNumbers = appNumbers.reduce((acc, appNum) => {
    if (!acc[appNum.yearPart]) {
        acc[appNum.yearPart] = [];
    }
    acc[appNum.yearPart].push(appNum);
    return acc;
}, {} as Record<string, typeof appNumbers>);
---

<Layout title="出願番号の一覧">
    <main class="p-4">
        <BreadCrumbs
            crumbs={[
                { title: "HOME", href: "/" },
                { title: "出願書類", href: "/docs" },
                { title: "出願番号の一覧", href: "/docs/applicationNumbers", },
            ]}
        />

        <section>
            <h1 class="text-2xl font-bold">出願番号の一覧</h1>
            <span class="text-sm text-gray-600">
                総数: {appNumbers.length} 件
            </span>
            {
                Object.keys(groupedAppNumbers).map((yearPart) => (
                    <h2>{yearPart}年</h2>
                    <ul class="pl-[2em] list-disc list-inside">
                        {groupedAppNumbers[yearPart].map((appNumber) => (
                            <li>
                                <a
                                    href={`/docs/applicationNumbers/${appNumber.slug}`}
                                    class="text-blue-600 hover:underline"
                                >
                                    {appNumber.applicationNumberString} {appNumber.fileReferenceId && `(${appNumber.fileReferenceId})`}  
                                </a>
                                {appNumber.numOfDocs > 1 && (
                                    <span class="text-gray-500 text-sm">
                                        (書類数: {appNumber.numOfDocs} 件)
                                    </span>
                                )}
                            </li>
                        ))}
                    </ul>
                ))
            }
        </section>
    </main>
</Layout>
