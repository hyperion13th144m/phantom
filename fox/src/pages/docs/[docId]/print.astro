---
import PrintingApplication from "~/components/application/ApplicationForPrinting.astro";
import PrintingPatentResponse from "~/components/application/PatentResponseForPrinting.astro";
import PrintingLayout from "~/layouts/PrintingLayout.astro";
import { getDocIds } from "~/lib/getDocPaths";
import { getIPDocument } from "~/lib/getIPDocument";

export const getStaticPaths = getDocIds;

const { docId } = Astro.params as { docId: string };
const ipDocument = await getIPDocument(docId);
const title = `${ipDocument.applicationNumber.toString()} | ${ipDocument.documentName}`;
---

<PrintingLayout title={title}>
    {
        ipDocument.documentCode == "A163" && (
            <PrintingApplication ipDocument={ipDocument} />
        )
    }
    {
        (ipDocument.documentCode == "A153" ||
            ipDocument.documentCode == "A159") && (
            <PrintingPatentResponse ipDocument={ipDocument} />
        )
    }
</PrintingLayout>
