{
    "name": "fox",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "dev": "astro dev --host 0.0.0.0",
        "build": "yarn run build:db && astro build",
        "preview": "astro preview --host 0.0.0.0",
        "start": "node ./dist/server/entry.mjs",
        "astro": "astro",
        "build:db": "tsx ./src/scripts/build-index-db.ts",
        "codegen": "json2ts ../shared/schema/patent-document-schema.json ./src/interfaces/patent-document-schema.ts"
    },
    "dependencies": {
        "@astrojs/node": "^9.5.2",
        "@tailwindcss/vite": "^4.1.18",
        "astro": "^5.16.6",
        "better-sqlite3": "^12.6.2",
        "rotating-file-stream": "^3.2.7",
        "tailwindcss": "^4.1.18"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "json-schema-to-typescript": "^15.0.4",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}