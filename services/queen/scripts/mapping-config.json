{
    "_comment": "generate-mapping.py の設定ファイル。full-text.json の JSON Schema から Elasticsearch マッピングを生成する際の変換ルールを定義します。",
    "settings": {
        "analysis": {
            "char_filter": {
                "normalize": {
                    "type": "icu_normalizer",
                    "name": "nfkc",
                    "mode": "compose"
                }
            },
            "tokenizer": {
                "my_ngram_tokenizer": {
                    "type": "ngram",
                    "min_gram": "2",
                    "max_gram": "2",
                    "token_chars": [
                        "letter",
                        "digit"
                    ]
                }
            },
            "analyzer": {
                "my_kuromoji_analyzer": {
                    "type": "custom",
                    "char_filter": [
                        "normalize"
                    ],
                    "tokenizer": "kuromoji_tokenizer",
                    "filter": [
                        "kuromoji_baseform",
                        "kuromoji_part_of_speech",
                        "ja_stop",
                        "kuromoji_stemmer",
                        "lowercase"
                    ]
                },
                "my_ngram_analyzer": {
                    "type": "custom",
                    "char_filter": [
                        "normalize"
                    ],
                    "tokenizer": "my_ngram_tokenizer",
                    "filter": [
                        "lowercase"
                    ]
                }
            }
        }
    },
    "_comment_exclude_fields": "JSON Schema には存在するが、ES マッピングには含めないフィールド。",
    "exclude_fields": [],
    "_comment_field_overrides": "デフォルト変換 (string→keyword) を上書きするフィールドの ES マッピング定義。",
