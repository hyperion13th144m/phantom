---
import { formatApplicationNumber } from "~/lib/bibliography";

const { law, appNumber } = Astro.props as {
    law: string;
    appNumber: string;
};
---

<div class="bg-orange-200 rounded-md shadow-md px-2">
    <a href={`/docList?law=${law}&applicationNumber=${appNumber}`}>
        {formatApplicationNumber(law, appNumber)}
    </a>
</div>
