---
interface Props {
    crumbs: { title: string; href: string }[];
}
---

<nav aria-label="Breadcrumb" class="text-sm mb-4">
    <ol class="list-none p-0 inline-flex space-x-2">
        {
            Astro.props.crumbs.map((crumb, index) => (
                <li>
                    {index > 0 && <span class="mx-2 text-gray-500">/</span>}
                    {index < Astro.props.crumbs.length - 1 ? (
                        <a
                            href={crumb.href}
                            class="text-blue-600 hover:underline"
                        >
                            {crumb.title}
                        </a>
                    ) : (
                        <span class="font-semibold">{crumb.title}</span>
                    )}
                </li>
            ))
        }
    </ol>
</nav>
