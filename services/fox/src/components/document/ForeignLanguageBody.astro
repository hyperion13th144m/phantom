---
// ApplicationBody の文書の表示用/印刷用レイアウトを定義、
// 子要素は items/ApplicationBodyItems.astro で定義する。
import Card from "~/components/ui/Card.astro";
import type { ForeignLanguageBody } from "~/interfaces/generated/foreign-language-body";
import { isForeignLanguageDocuments } from "~/interfaces/generated/foreign-language-body.guard";
import PatCommon from "./items/PatCommon.astro";

const { document, forPrinting = false } = Astro.props as {
    document: ForeignLanguageBody;
    forPrinting: boolean;
};
const displayOrder = [
    "jp:foreign-language-abstract",
    "jp:foreign-language-claims",
    "jp:foreign-language-description",
    "jp:foreign-language-drawings",
];
const printingOrder = [
    "jp:foreign-language-description",
    "jp:foreign-language-claims",
    "jp:foreign-language-abstract",
    "jp:foreign-language-drawings",
];
const order = forPrinting ? printingOrder : displayOrder;
const sortedDocs = order
    .map((tag) =>
        document.blocks.find(
            (b) => isForeignLanguageDocuments(b) && b.tag === tag,
        ),
    )
    .filter((b): b is NonNullable<typeof b> => b !== undefined);
---

{
    forPrinting === false &&
        sortedDocs.map((block) => (
            <Card title={block.text}>
                <div class={block.tag}>
                    {block.blocks.map((b) => (
                        <PatCommon block={b} />
                    ))}
                </div>
            </Card>
        ))
}

{
    forPrinting === true &&
        sortedDocs.map((block) => (
            <div class={block.tag}>
                <div>
                    {block.jpTag}
                    {block.text}
                </div>
                {block.blocks.map((b) => (
                    <PatCommon block={b} />
                ))}
            </div>
        ))
}

<!-- for printing -->
<style>
    .claims {
        break-before: page;
    }
    .description {
        break-before: page;
    }
    .abstract {
        break-before: page;
    }
    .drawings {
        break-before: page;
    }
</style>
