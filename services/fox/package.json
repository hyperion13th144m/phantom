{
    "name": "fox",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "dev": "astro dev --host 0.0.0.0",
        "build": "env NODE_ENV=production astro build",
        "preview": "astro preview --host 0.0.0.0",
        "start": "node ./dist/server/entry.mjs",
        "astro": "astro",
        "setup-logging": "bash ./scripts/setup-logging.sh",
        "test": "vitest",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest --coverage",
        "test:compare": "vitest --run __tests__/fixtures/compare-html-fixtures.test.ts",
        "render:documents": "vitest --run --config vitest.render.config.ts __tests__/fixtures/render-document-fixtures.test.ts"
    },
    "dependencies": {
        "@astrojs/node": "^9.5.4",
        "@tailwindcss/vite": "^4.1.18",
        "astro": "5.17.3",
        "pino": "^10.3.1",
        "pino-rotating-file-stream": "^0.0.2",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3"
    },
    "devDependencies": {
        "@types/node": "^25.3.0",
        "@vitest/ui": "^4.0.18",
        "chai": "^6.2.2",
        "cheerio": "^1.2.0",
        "vitest": "^4.0.18"
    }
}